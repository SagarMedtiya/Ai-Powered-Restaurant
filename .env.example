# LLM Configuration (Groq — get your key at https://console.groq.com/keys)
LLM_API_KEY=your_groq_api_key_here
# Groq uses an OpenAI-compatible API — Spring AI appends /v1 automatically
LLM_BASE_URL=https://api.groq.com/openai

# Dataset Configuration
# Remote URL for the full Zomato dataset CSV
DATASET_URL=https://huggingface.co/datasets/ManikaSaini/zomato-restaurant-recommendation/resolve/main/zomato.csv
# Local cache path where the downloaded dataset is saved
DATASET_CACHE_PATH=./data/cache/zomato.csv
